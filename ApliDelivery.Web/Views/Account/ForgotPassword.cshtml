@model ApliDelivery.Web.Models.RecuperarPasswordDTO

@{
    ViewData["Title"] = "Recuperar contraseña";
}

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-5">

            <div class="card shadow-lg border-0 rounded-4">

                <div class="card-body p-5">

                    <div class="text-center mb-4">

                        <h1 class="text-danger">🔒</h1>

                        <h2 class="fw-bold">
                            Recuperar contraseña
                        </h2>

                        <p class="text-muted">
                            Ingresa tu correo para recuperar tu cuenta.
                        </p>

                    </div>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">
                            @ViewBag.Error
                        </div>
                    }

                    <!-- FORMULARIO PARA GENERAR EL CÓDIGO -->

                    <form asp-action="ForgotPassword" method="post">

                        <div class="mb-4">

                            <label class="form-label">
                                Correo electrónico
                            </label>

                            <input asp-for="Correo"
                                   class="form-control form-control-lg"
                                   placeholder="Ingrese su correo" />

                        </div>

                        <button type="submit"
                                class="btn btn-danger btn-lg w-100">

                            Enviar código

                        </button>

                    </form>

                    @if (ViewBag.Codigo != null)
                    {
                        <div class="alert alert-success mt-4">

                            <strong>✅ Código generado correctamente.</strong>

                            <br /><br />

                            <strong>Su código de recuperación es:</strong>

                            <h3 class="text-center text-danger">
                                @ViewBag.Codigo
                            </h3>

                            <p class="mt-3 mb-0 text-center">
                                Utilice este código para cambiar su contraseña.
                            </p>

                        </div>
                    }

                    @if (ViewBag.MostrarCambio == true)
                    {
                        <hr />

                        <h4 class="text-center mt-4 mb-3">
                            Cambiar contraseña
                        </h4>

                        <form asp-action="CambiarPassword" method="post">

                            <input type="hidden"
                                   name="correo"
                                   value="@ViewBag.Correo" />

                            <div class="mb-3">

                                <label class="form-label">
                                    Código
                                </label>

                                <input type="text"
                                       name="codigo"
                                       class="form-control"
                                       placeholder="Ingrese el código" />

                            </div>

                            <div class="mb-4">

                                <label class="form-label">
                                    Nueva contraseña
                                </label>

                                <input type="password"
                                       name="nuevaPassword"
                                       class="form-control"
                                       placeholder="Ingrese la nueva contraseña" />

                            </div>

                            <button type="submit"
                                    class="btn btn-success btn-lg w-100">

                                Cambiar contraseña

                            </button>

                        </form>
                    }

                    <div class="text-center mt-4">

                        <a asp-controller="Account"
                           asp-action="Login">

                            Volver al inicio de sesión

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>