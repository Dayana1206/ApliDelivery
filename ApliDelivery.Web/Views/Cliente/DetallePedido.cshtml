@{
    ViewData["Title"] = "Detalle del Pedido";
}


<div class="container mt-5">


    <div class="text-center mb-4">

        <h1 class="fw-bold text-danger">
            Detalle del Pedido
        </h1>

        <p class="text-muted">
            Información de tu compra
        </p>

    </div>



    <div class="row">


        <div class="col-md-6">


            <div class="card shadow border-0 p-4">


                <h4>
                    Productos
                </h4>

                <hr>


                <p>
                    Pizza familiar ........ $12.00
                </p>


                <p>
                    Gaseosa ............... $2.00
                </p>


                <p>
                    Papas fritas .......... $3.00
                </p>


                <hr>


                <h5>
                    Total: $17.00
                </h5>


            </div>


        </div>




        <div class="col-md-6">


            <div class="card shadow border-0 p-4">


                <h4>
                    Información
                </h4>


                <hr>


                <p>
                    <strong>Número:</strong>
                    #001
                </p>


                <p>
                    <strong>Estado:</strong>

                    <span class="badge bg-warning text-dark">
                        Preparando
                    </span>

                </p>


                <p>
                    <strong>Dirección:</strong>
                    Calle Principal
                </p>


                <p>
                    <strong>Restaurante:</strong>
                    Pizza House
                </p>


                <p>
                    <strong>Repartidor:</strong>
                    Pendiente
                </p>


            </div>


        </div>


    </div>



    <div class="text-center mt-4">


        <a class="btn btn-danger btn-lg"
           asp-controller="Cliente"
           asp-action="Pedidos">

            Volver a pedidos

        </a>
        <a class="btn btn-success btn-lg"
           asp-controller="Cliente"
           asp-action="Seguimiento">

            Ver seguimiento

        </a>


    </div>


</div>