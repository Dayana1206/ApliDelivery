@{
    ViewData["Title"] = "Detalle del Pedido";
}

<div class="container mt-5">

    <div class="text-center mb-5">

        <h1 class="fw-bold text-danger">
            Detalle del Pedido
        </h1>

        <p class="text-muted">
            Consulta toda la información de tu pedido.
        </p>

    </div>

    <div class="row">

        <!-- Productos -->

        <div class="col-lg-6 mb-4">

            <div class="card shadow border-0 rounded-4">

                <div class="card-body">

                    <h4 class="fw-bold">
                        Productos
                    </h4>

                    <hr />

                    <table class="table">

                        <thead>

                            <tr>

                                <th>Producto</th>

                                <th>Cantidad</th>

                                <th>Precio</th>

                            </tr>

                        </thead>

                        <tbody>

                            <tr>

                                <td>Pizza Suprema</td>

                                <td>1</td>

                                <td>$12.99</td>

                            </tr>

                            <tr>

                                <td>Gaseosa</td>

                                <td>2</td>

                                <td>$3.00</td>

                            </tr>

                            <tr>

                                <td>Papas Fritas</td>

                                <td>1</td>

                                <td>$2.50</td>

                            </tr>

                        </tbody>

                    </table>

                    <hr />

                    <h4 class="text-danger text-end">

                        Total: $18.49

                    </h4>

                </div>

            </div>

        </div>

        <!-- Información -->

        <div class="col-lg-6 mb-4">

            <div class="card shadow border-0 rounded-4">

                <div class="card-body">

                    <h4 class="fw-bold">
                        Información del Pedido
                    </h4>

                    <hr />

                    <p>

                        <strong>Número:</strong>

                        #001

                    </p>

                    <p>

                        <strong>Restaurante:</strong>

                        Pizza Hut

                    </p>

                    <p>

                        <strong>Estado:</strong>

                        <span class="badge bg-warning text-dark">

                            Preparando

                        </span>

                    </p>

                    <p>

                        <strong>Dirección:</strong>

                        Av. Mariano Acosta, Ibarra

                    </p>

                    <p>

                        <strong>Fecha:</strong>

                        09/07/2026

                    </p>

                    <p>

                        <strong>Hora:</strong>

                        19:35

                    </p>

                    <p>

                        <strong>Repartidor:</strong>

                        Carlos Pérez

                    </p>

                </div>

            </div>

        </div>

    </div>

    <div class="text-center mt-4">

        <a asp-action="Pedidos"
           class="btn btn-secondary btn-lg">

            Volver

        </a>

        <a asp-action="Seguimiento"
           class="btn btn-danger btn-lg">

            Ver Seguimiento

        </a>

    </div>

</div>