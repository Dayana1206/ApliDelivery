@model ApliDelivery.Web.Models.PedidoDTO

@{
    ViewData["Title"] = "Detalle del Pedido";
}

<div class="container mt-5">

    <div class="text-center mb-5">

        <h1 class="fw-bold text-danger">
            Detalle del Pedido
        </h1>

    </div>

    <div class="row">

        <div class="col-lg-7">

            <div class="card shadow">

                <div class="card-body">

                    <h4>Productos</h4>

                    <hr />

                    <table class="table">

                        <thead>

                            <tr>

                                <th>Producto</th>

                                <th>Cantidad</th>

                                <th>Precio</th>

                                <th>Subtotal</th>

                            </tr>

                        </thead>

                        <tbody>

                            @foreach (var item in Model.Productos)
                            {
                                <tr>

                                    <td>@item.Nombre</td>

                                    <td>@item.Cantidad</td>

                                    <td>$ @item.Precio</td>

                                    <td>$ @item.Subtotal</td>

                                </tr>
                            }

                        </tbody>

                    </table>

                    <hr />

                    <h4 class="text-end text-danger">

                        Total: $ @Model.Total

                    </h4>

                </div>

            </div>

        </div>

        <div class="col-lg-5">

            <div class="card shadow">

                <div class="card-body">

                    <h4>Información</h4>

                    <hr />

                    <p>

                        <strong>Pedido:</strong>

                        #@Model.PedidoId

                    </p>

                    <p>

                        <strong>Fecha:</strong>

                        @Model.Fecha.ToString("dd/MM/yyyy HH:mm")

                    </p>

                    <p>

                        <strong>Estado:</strong>

                        <span class="badge bg-warning">

                            @Model.Estado

                        </span>

                    </p>

                </div>

            </div>

        </div>

    </div>

    <div class="mt-4">

        <a asp-action="Pedidos"
           class="btn btn-secondary">

            ← Volver

        </a>

    </div>

</div>