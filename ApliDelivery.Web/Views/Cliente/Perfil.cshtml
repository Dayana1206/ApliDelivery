@model ApliDelivery.Web.Models.UsuarioDTO

@{
    ViewData["Title"] = "Mi Perfil";
}

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-lg-7">

            <div class="card shadow border-0 rounded-4">

                <div class="card-body p-5">

                    <div class="text-center mb-5">

                        <h1>👤</h1>

                        <h2 class="fw-bold text-danger">
                            Mi Perfil
                        </h2>

                        <p class="text-muted">
                            Consulta y actualiza tu información personal.
                        </p>

                    </div>

                    @if (ViewBag.Mensaje != null)
                    {
                        <div class="alert alert-success">
                            @ViewBag.Mensaje
                        </div>
                    }

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">
                            @ViewBag.Error
                        </div>
                    }

                    <form asp-action="GuardarPerfil" method="post">

                        <div class="row">

                            <div class="col-md-6 mb-3">

                                <label class="form-label">
                                    Nombre
                                </label>

                                <input asp-for="Nombre"
                                       class="form-control"
                                       readonly />

                            </div>

                            <div class="col-md-6 mb-3">

                                <label class="form-label">
                                    Apellido
                                </label>

                                <input asp-for="Apellido"
                                       class="form-control"
                                       readonly />

                            </div>

                        </div>

                        <div class="mb-3">

                            <label class="form-label">
                                Correo electrónico
                            </label>

                            <input asp-for="Correo"
                                   class="form-control"
                                   readonly />

                        </div>

                        <div class="mb-3">

                            <label class="form-label">
                                Teléfono
                            </label>

                            <input name="Telefono"
                                   value="@Model.Telefono"
                                   class="form-control" />

                        </div>

                        <div class="mb-3">

                            <label class="form-label">
                                Estado
                            </label>

                            <input class="form-control"
                                   value="@(Model.Estado ? "Activo" : "Inactivo")"
                                   readonly />

                        </div>

                        <div class="mb-3">

                            <label class="form-label">
                                Fecha de registro
                            </label>

                            <input class="form-control"
                                   value="@Model.FechaRegistro.ToString("dd/MM/yyyy")"
                                   readonly />

                        </div>

                        <div class="d-grid gap-2">

                            <button type="submit"
                                    class="btn btn-danger btn-lg">

                                Guardar cambios

                            </button>

                            <a asp-action="Index"
                               class="btn btn-outline-secondary">

                                Volver al Panel

                            </a>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>