@{
    ViewData["Title"] = "Mis Pedidos";
}

<div class="container mt-5">

    <div class="text-center mb-5">

        <h1 class="fw-bold text-danger">
            Mis Pedidos
        </h1>

        <p class="text-muted">
            Revisa el estado y la información de tus pedidos realizados.
        </p>

    </div>

    <div class="row">

        <!-- PEDIDO 1 -->
        <div class="col-lg-4 col-md-6 mb-4">

            <div class="card shadow border-0 rounded-4 h-100">

                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">

                        <h4 class="fw-bold">
                            Pedido #001
                        </h4>

                        <span class="badge bg-warning text-dark">
                            Preparando
                        </span>

                    </div>

                    <hr />

                    <p>
                        <strong>Restaurante:</strong>
                        Pizza Hut
                    </p>

                    <p>
                        <strong>Fecha:</strong>
                        09/07/2026
                    </p>

                    <p>
                        <strong>Total:</strong>
                        $15.50
                    </p>

                    <a asp-controller="Cliente"
                       asp-action="DetallePedido"
                       asp-route-id="1"
                       class="btn btn-danger w-100 mb-2">

                        Ver detalle

                    </a>

                    <a asp-controller="Cliente"
                       asp-action="Seguimiento"
                       class="btn btn-outline-danger w-100">

                        Ver seguimiento

                    </a>

                </div>

            </div>

        </div>

        <!-- PEDIDO 2 -->
        <div class="col-lg-4 col-md-6 mb-4">

            <div class="card shadow border-0 rounded-4 h-100">

                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">

                        <h4 class="fw-bold">
                            Pedido #002
                        </h4>

                        <span class="badge bg-info text-dark">
                            En camino
                        </span>

                    </div>

                    <hr />

                    <p>
                        <strong>Restaurante:</strong>
                        Encebollados del Norte
                    </p>

                    <p>
                        <strong>Fecha:</strong>
                        08/07/2026
                    </p>

                    <p>
                        <strong>Total:</strong>
                        $6.50
                    </p>

                    <a asp-controller="Cliente"
                       asp-action="DetallePedido"
                       asp-route-id="2"
                       class="btn btn-danger w-100 mb-2">

                        Ver detalle

                    </a>

                    <a asp-controller="Cliente"
                       asp-action="Seguimiento"
                       class="btn btn-outline-danger w-100">

                        Ver seguimiento

                    </a>

                </div>

            </div>

        </div>

        <!-- PEDIDO 3 -->
        <div class="col-lg-4 col-md-6 mb-4">

            <div class="card shadow border-0 rounded-4 h-100">

                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">

                        <h4 class="fw-bold">
                            Pedido #003
                        </h4>

                        <span class="badge bg-success">
                            Entregado
                        </span>

                    </div>

                    <hr />

                    <p>
                        <strong>Restaurante:</strong>
                        Sabor Oriental
                    </p>

                    <p>
                        <strong>Fecha:</strong>
                        06/07/2026
                    </p>

                    <p>
                        <strong>Total:</strong>
                        $8.50
                    </p>

                    <a asp-controller="Cliente"
                       asp-action="DetallePedido"
                       asp-route-id="3"
                       class="btn btn-danger w-100">

                        Ver detalle

                    </a>

                </div>

            </div>

        </div>

    </div>

</div>