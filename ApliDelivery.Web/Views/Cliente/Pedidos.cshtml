@{
    ViewData["Title"] = "Mis Pedidos";
}


<div class="container mt-5">

    <div class="text-center mb-5">

        <h1 class="fw-bold text-danger">
            Mis Pedidos
        </h1>

        <p class="text-muted">
            Revisa el estado de tus pedidos realizados.
        </p>

    </div>


    <div class="row">
        <div class="col-md-4 mb-4">

            <div class="card shadow border-0">

                <div class="card-body">

                    <h4>
                        Pedido #001
                    </h4>

                    <hr>

                    <p>
                        <strong>Restaurante:</strong>
                        Pizza House
                    </p>

                    <p>
                        <strong>Total:</strong>
                        $15.50
                    </p>

                    <p>
                        <strong>Estado:</strong>
                        <span class="badge bg-warning text-dark">
                            Preparando
                        </span>
                    </p>


                    <a class="btn btn-danger w-100"
                       asp-controller="Cliente"
                       asp-action="DetallePedido">

                        Ver detalle

                    </a>


                </div>

            </div>

        </div>

        <div class="col-md-4 mb-4">

            <div class="card shadow border-0">

                <div class="card-body">

                    <h4>
                        Pedido #002
                    </h4>

                    <hr>

                    <p>
                        <strong>Restaurante:</strong>
                        Encebollado
                    </p>

                    <p>
                        <strong>Total:</strong>
                        $2.50
                    </p>

                    <p>
                        <strong>Estado:</strong>

                        <span class="badge bg-info">
                            En camino
                        </span>

                    </p>


                    <button class="btn btn-danger w-100">
                        Ver detalle
                    </button>


                </div>

            </div>

        </div>

        <div class="col-md-4 mb-4">

            <div class="card shadow border-0">

                <div class="card-body">

                    <h4>
                        Pedido #003
                    </h4>

                    <hr>

                    <p>
                        <strong>Restaurante:</strong>
                        Chaulafán
                    </p>


                    <p>
                        <strong>Total:</strong>
                        $8.50
                    </p>


                    <p>
                        <strong>Estado:</strong>

                        <span class="badge bg-success">
                            Entregado
                        </span>

                    </p>


                    <button class="btn btn-danger w-100">
                        Ver detalle
                    </button>


                </div>

            </div>

        </div>


    </div>


</div>