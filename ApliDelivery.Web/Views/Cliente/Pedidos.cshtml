@model List<ApliDelivery.Web.Models.PedidoDTO>

@{
    ViewData["Title"] = "Mis Pedidos";
}

<div class="container mt-5">

    <h2 class="fw-bold text-danger mb-4">

        Mis Pedidos

    </h2>

    @if (TempData["PedidoConfirmado"] != null)
    {
        <div class="alert alert-success">

            @TempData["PedidoConfirmado"]

        </div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-warning">

            No tienes pedidos realizados.

        </div>
    }
    else
    {
        @foreach (var pedido in Model)
        {
            <div class="card shadow mb-4">

                <div class="card-body">

                    <div class="d-flex justify-content-between">

                        <h4>

                            Pedido #@pedido.PedidoId

                        </h4>

                        <span class="badge bg-warning">

                            @pedido.Estado

                        </span>

                    </div>

                    <hr />

                    <p>

                        <strong>Fecha:</strong>

                        @pedido.Fecha.ToString("dd/MM/yyyy HH:mm")

                    </p>

                    <p>

                        <strong>Total:</strong>

                        $ @pedido.Total

                    </p>

                    <a asp-action="DetallePedido"
                       asp-route-id="@pedido.PedidoId"
                       class="btn btn-danger">

                        Ver detalle

                    </a>

                    <a asp-action="Seguimiento"
                       asp-route-id="@pedido.PedidoId"
                       class="btn btn-outline-danger">

                        Seguimiento

                    </a>

                </div>

            </div>
        }
    }

</div>