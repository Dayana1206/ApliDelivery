@{
    ViewData["Title"] = "Seguimiento del Pedido";
}


<div class="container mt-5">


    <div class="text-center mb-4">

        <h1 class="fw-bold text-danger">
            Seguimiento de Pedido
        </h1>

        <p class="text-muted">
            Mira el estado de tu pedido en tiempo real.
        </p>

    </div>
    <div class="row">


        <div class="col-md-8">


            <div class="card shadow border-0">


                <div class="card-body text-center">


                    <h3>
                        Mapa de ubicación
                    </h3>


                    <div class="mt-4 p-5 bg-light rounded">

                        <p>
                            Aquí aparecerá el mapa y la ruta del repartidor.
                        </p>

                    </div>


                </div>


            </div>


        </div>
        <div class="col-md-4">
            <div class="card shadow border-0 p-4">


                <h4>
                    Estado del pedido
                </h4>


                <hr>


                <p>
                    Pedido confirmado
                </p>


                <p>
                    Preparando comida
                </p>


                <p>
                    En camino
                </p>


                <p>
                    Entregado
                </p>


                <hr>


                <p>
                    Repartidor: Pendiente
                </p>


                <p>
                    Tiempo estimado:25 minutos
                </p>


            </div>


        </div>


    </div>


</div>