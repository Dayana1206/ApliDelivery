@model ApliDelivery.Web.Models.PedidoDTO

@{
    ViewData["Title"] = "Seguimiento del Pedido";
}

<div class="container mt-5">

    <div class="text-center mb-4">
        <h1 class="fw-bold text-danger">
            Seguimiento de Pedido
        </h1>

        <p class="text-muted">
            Mira el estado de tu pedido en tiempo real.
        </p>
    </div>

    <div class="row">

        <!-- MAPA -->
        <div class="col-lg-8">

            <div class="card shadow border-0 rounded-4">

                <div class="card-body">

                    <h3 class="text-center mb-3">
                        Mapa de ubicación
                    </h3>

                    <div id="map"
                         class="rounded border border-2 shadow-sm"
                         style="height:600px;">
                    </div>

                </div>

            </div>

        </div>

        <!-- PANEL DERECHO -->
        <div class="col-lg-4">

            <div class="card shadow border-0 rounded-4">

                <div class="card-body">

                    <h4 class="fw-bold text-center">
                        Estado del pedido
                    </h4>

                    <hr>

                    <p>🟢 <strong>Pedido confirmado</strong></p>

                    <p>🟢 <strong>Preparando comida</strong></p>

                    <p>🟡 <strong>En camino</strong></p>

                    <p>⚪ <strong>Entregado</strong></p>

                    <hr>

                    <h5 class="fw-bold">
                        Información del pedido
                    </h5>

                    <p><strong>Pedido:</strong> #001</p>

                    <p><strong>Restaurante:</strong> Pizza Hut</p>

                    <p><strong>Cliente:</strong> @Model.Cliente</p>

                    <p><strong>Repartidor:</strong> Carlos Pérez</p>

                    <p><strong>Vehículo:</strong> Motocicleta</p>

                    <p><strong>Tiempo estimado:</strong> 25 minutos</p>

                    <p><strong>Distancia:</strong> 1.6 km</p>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {

    <script>

        // ==========================
        // MAPA
        // ==========================

        var map = L.map('map').setView([0.3535, -78.1200], 15);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; OpenStreetMap'
        }).addTo(map);

        // ==========================
        // UBICACIONES
        // ==========================

        var restaurante = [0.34924, -78.12517];

        var repartidor = [0.35320, -78.11850];

        var cliente = [0.35789, -78.11187];

        // ==========================
        // MARCADORES
        // ==========================

        L.marker(restaurante)
            .addTo(map)
            .bindPopup("<b>🍕 Pizza Hut</b><br>Restaurante");

        L.marker(repartidor)
            .addTo(map)
            .bindPopup("<b>🛵 Carlos Pérez</b><br>Repartidor");

        L.marker(cliente)
            .addTo(map)
            .bindPopup("<b>🏫 Universidad Técnica del Norte</b><br>Cliente");

        // ==========================
        // RUTA
        // ==========================

        var ruta = L.polyline([

            restaurante,

            [0.35020, -78.12430],

            [0.35120, -78.12280],

            [0.35210, -78.12120],

            repartidor,

            [0.35450, -78.11680],

            [0.35600, -78.11400],

            cliente

        ], {
            color: "#FF6B35",
            weight: 6,
            opacity: 0.9
        }).addTo(map);

        map.fitBounds(ruta.getBounds());

    </script>

}