@{
    ViewData["Title"] = "Panel Administrador";
}


<div class="container mt-5">


    <div class="text-center">

        <h1 class="fw-bold text-danger">
            Panel Administrador
        </h1>

        <p class="lead">
            Gestión general de ApliDelivery
        </p>

    </div>



    <div class="row mt-5">


        <div class="col-md-4">


            <div class="card shadow p-4 text-center">

                <h4>
                    Clientes
                </h4>


                <p>
                    Administrar usuarios registrados.
                </p>


                <a class="btn btn-danger"
                   asp-action="Clientes">

                    Gestionar

                </a>


            </div>


        </div>

        <div class="col-md-4">


            <div class="card shadow p-4 text-center">


                <h4>
                    Administradores
                </h4>


                <p>
                    Gestionar cuentas administrativas.
                </p>


                <a class="btn btn-danger"
                   asp-action="Administradores">

                    Gestionar

                </a>


            </div>


        </div>

        <div class="col-md-4">


            <div class="card shadow p-4 text-center">

                <h4>
                    Reportes
                </h4>


                <p>
                    Revisar información del sistema.
                </p>


                <a class="btn btn-danger"
                   asp-controller="Administrador"
                   asp-action="Reportes">

                    Ver reportes

                </a>
            </div>
        </div>
    </div>
</div>