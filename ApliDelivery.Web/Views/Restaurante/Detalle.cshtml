@{
    ViewData["Title"] = "Detalle del Producto";
}

<div class="container mt-5">

    <div class="row">

        <!-- Imagen -->

        <div class="col-md-6">

            <div class="card shadow border-0 rounded-4">

                <img src="https://images.unsplash.com/photo-1513104890138-7c749659a591?w=800"
                     class="img-fluid rounded-4"
                     alt="Pizza">

            </div>

        </div>

        <!-- Información -->

        <div class="col-md-6">

            <h1 class="fw-bold text-danger">
                Pizza Suprema
            </h1>

            <p class="text-muted">
                Pizza familiar preparada con ingredientes frescos y queso mozzarella.
            </p>

            <hr />

            <h4>
                Ingredientes
            </h4>

            <ul>

                <li>Pepperoni</li>

                <li>Jamón</li>

                <li>Champiñones</li>

                <li>Queso Mozzarella</li>

                <li>Salsa de tomate</li>

            </ul>

            <h3 class="text-danger mt-4">

                $12.99

            </h3>

            <div class="mt-4">

                <label class="form-label">

                    Cantidad

                </label>

                <input type="number"
                       class="form-control"
                       value="1"
                       min="1"
                       style="width:120px;">

            </div>

            <div class="mt-4">

                <button class="btn btn-danger btn-lg">

                    Agregar al carrito

                </button>

                <a asp-action="Menu"
                   class="btn btn-secondary btn-lg">

                    Volver

                </a>

            </div>

        </div>

    </div>

</div>
